@inherits ErrorBoundary

@if (CurrentException is null)
{
    @ChildContent
}
else
{
    <div class="alert alert-danger p-4 m-3" style="border: 2px solid #dc3545; border-radius: 8px; background-color: #f8d7da;">
        <h4 class="alert-heading">⚠️ Data Processing Error</h4>
        <p>The application encountered an issue while parsing the Legislative XML.</p>
        <hr>
        <p class="mb-0"><strong>Technical Details:</strong> @CurrentException.Message</p>
        
        <button class="btn btn-outline-danger mt-3" @onclick="Recover">
            Reset View & Try Again
        </button>
    </div>
}

@code {
    protected override void OnParametersSet()
    {
        // This resets the error state if the user navigates away or updates parameters
        Recover();
    }
}
