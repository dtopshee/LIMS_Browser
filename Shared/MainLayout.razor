@inherits LayoutComponentBase
@namespace LegislationTimeMachine.Shared

<div class="page">
    <main>
        <div class="top-row px-4">
            <span class="app-title">⚖️ Legislation Time Machine</span>
            <a href="https://github.com/your-username/LegislationTimeMachine" target="_blank">View on GitHub</a>
        </div>

        <article class="content px-4">
            <ErrorBoundaryLogger>
                @Body
            </ErrorBoundaryLogger>
        </article>
    </main>
</div>

<style>
    .top-row {
        height: 3.5rem;
        background-color: #2c3e50;
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .app-title {
        font-weight: bold;
        font-size: 1.2rem;
    }
    .page {
        position: relative;
        display: flex;
        flex-direction: column;
    }
    main {
        flex: 1;
    }
    .content {
        padding-top: 1.1rem;
    }
</style>
