@page "/"
@inject LegislationTimeMachine.Services.LegislationStateService State
@inject IJSRuntime JS
@using LegislationTimeMachine.Models
@using LegislationTimeMachine.Services

@if (!State.IsLoading && State.MasterNodes.Any())
{
    <div class="stats-bar" style="display: flex; gap: 20px; padding: 10px 20px; background: #f8f9fa; border-bottom: 1px solid #ddd; font-family: sans-serif; font-size: 0.9em;">
        <span style="color: #666;">Analysis of <strong>@State.CurrentActTitle</strong> (@State.LeftYear vs. Current):</span>
        
        <span title="Added since @State.LeftYear">
            <strong style="color: #28a745;">● @AddedCount</strong> Added
        </span>
        
        <span title="Modified since @State.LeftYear">
            <strong style="color: #fbc02d;">● @ModifiedCount</strong> Modified
        </span>
        
        <span title="Repealed or removed since @State.LeftYear">
            <strong style="color: #d73a49;">● @RemovedCount</strong> Repealed/Removed
        </span>
    </div>
}

<div class="act-selector" style="padding: 15px; background: #eee; border-bottom: 2px solid #ccc; display: flex; align-items: center; gap: 20px;">
    <strong>Active Act:</strong>
    <select class="form-select" @onchange="OnActSelected" style="padding: 5px; border-radius: 4px;">
        <option value="">-- Choose Legislation --</option>
        @foreach (var act in State.AvailableActs)
        {
            <option value="@act.FileName">@act.ShortTitle</option>
        }
    </select>
    <span>Year: <strong>@State.LeftYear</strong></span>
</div>

<div class="timeline-header" style="padding: 20px; background: #eee; border-bottom: 1px solid #ccc;">
    <div class="slider-controls">
        <label>Historical Snapshot (Year): @State.LeftYear</label>
        <input type="range" min="2003" max="2026" @bind-value="State.LeftYear" @bind-value:event="oninput" style="width: 100%;" />
    </div>
    <div class="metadata">
        <span>Comparing <strong>@State.LeftDate.ToShortDateString()</strong> to <strong>Current Laws</strong></span>
    </div>
</div>

<div class="diff-container" style="display: flex; height: 80vh; overflow: hidden; background: white;">
    
    @* Left Pane: Historical View *@
    <div class="pane" data-fid="TOP" id="leftPane" style="flex: 1; overflow-y: auto; border-right: 2px solid #ddd;">
        <h3 style="padding: 10px; background: #f4f4f4; margin: 0; position: sticky; top: 0; z-index: 10;">
            Archive: @State.LeftYear
        </h3>
        <Virtualize Items="@LeftNodes" Context="historicalNode">
            @RenderNode(historicalNode)
        </Virtualize>
    </div>

    @* Right Pane: Current View *@
    <div class="pane" id="rightPane" data-fid="TOP" style="flex: 1; overflow-y: auto;">
        <h3 style="padding: 10px; background: #f4f4f4; margin: 0; position: sticky; top: 0; z-index: 10;">
            Current Legislation
        </h3>
        <Virtualize Items="@RightNodes" Context="currentNode">
            @RenderNode(currentNode)
        </Virtualize>
    </div>
</div>

@code {
    private List<LegislativeNode> LeftNodes = new();
    private List<LegislativeNode> RightNodes = new();
    private Dictionary<string, LegislativeDelta> DiffResults = new();

protected override async Task OnInitializedAsync()
    {
        State.OnChange += async () => await RefreshData();
        await State.LoadAvailableActsAsync();
        
        // Default to Privacy Act on first load
        await State.LoadNewActAsync("PrivacyAct.xml");
    }

    private async Task OnActSelected(ChangeEventArgs e)
    {
        var file = e.Value?.ToString();
        if (!string.IsNullOrEmpty(file))
        {
            await State.LoadNewActAsync(file);
        }
    }

protected override void OnInitialized()
{
    // Subscribe to the state change event
    State.OnChange += async () => await RefreshData();
}

private int AddedCount { get; set; }
    private int ModifiedCount { get; set; }
    private int RemovedCount { get; set; }

    private async Task RefreshData()
    {
        // ... existing filtering and diffing code ...
        LeftNodes = LegislationParser.GetVersionAtDate(State.MasterNodes, State.LeftYear);
        RightNodes = LegislationParser.GetVersionAtDate(State.MasterNodes, 2026);
        DiffResults = DiffEngine.Compare(LeftNodes, RightNodes);

        // Calculate Stats based on the DiffResults dictionary
        AddedCount = DiffResults.Values.Count(d => d.Type == ChangeType.Added);
        ModifiedCount = DiffResults.Values.Count(d => d.Type == ChangeType.Modified);
        RemovedCount = DiffResults.Values.Count(d => d.Type == ChangeType.Removed);

        StateHasChanged();
    }

    private bool IsModified(string fid)
    {
        if (string.IsNullOrEmpty(fid)) return false;
        return DiffResults.TryGetValue(fid, out var delta) && delta.Type == ChangeType.Modified;
    }

    private string GetChangeClass(string fid) 
    {
        if (string.IsNullOrEmpty(fid) || !DiffResults.ContainsKey(fid)) return "unchanged";
        
        return DiffResults[fid].Type switch {
            ChangeType.Added => "diff-added",
            ChangeType.Removed => "diff-removed",
            ChangeType.Modified => "diff-mod",
            _ => "unchanged"
        };
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }

private void LoadMockData()
{

        LeftNodes.Clear();
    RightNodes.Clear();
    DiffResults.Clear();
    // Snapshot A: 2005 (Simple Section)
    var sectionOld = new LegislativeNode {
        Fid = "12345",
        Label = "3.1",
        MarginalNote = "INTERPRETATION",
        Content = "This section is a single sentence defining the scope of the Act.",
        ElementName = "Section"
    };
    LeftNodes = new List<LegislativeNode> { sectionOld };

    // Snapshot B: 2026 (The "Split" you identified)
    var sectionNew = new LegislativeNode {
        Fid = "12345", // Same FID
        Label = "3.1",
        MarginalNote = "INTERPRETATION",
        ElementName = "Section",
        Children = new List<LegislativeNode> {
            new LegislativeNode { 
                Fid = "12345-1", 
                Label = "(1)", 
                Content = "This section is a single sentence defining the scope of the Act.",
                ElementName = "Subsection" 
            },
            new LegislativeNode { 
                Fid = "67890", 
                Label = "(2)", 
                Content = "This is a brand new subsection added by an amending formula.",
                ElementName = "Subsection" 
            }
        }
    };
    RightNodes = new List<LegislativeNode> { sectionNew };

    // Mark it as Modified in the Diff Engine
    DiffResults["12345"] = new LegislativeDelta {
        Fid = "12345",
        Type = ChangeType.Modified,
        OldVersion = sectionOld,
        NewVersion = sectionNew
    };
}
protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender)
    {
        await JS.InvokeVoidAsync("syncScroll.init", "leftPane", "rightPane");
    }
}

RenderFragment RenderNode(LegislativeNode node) => __builder =>
    {
        // Determine if this specific provision is repealed at the selected point in time
        var isRepealed = node.RepealDate.HasValue && node.RepealDate.Value.Year <= State.LeftYear;
        var changeClass = GetChangeClass(node.Fid);

        <div class="node-row @(isRepealed ? "diff-removed" : changeClass)" 
             data-fid="@node.Fid" 
             style="margin-left: @(GetIndent(node.ElementName))px; padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
            
            @* 1. Render the Marginal Note (if it exists at this level) *@
            @if (!string.IsNullOrEmpty(node.MarginalNote))
            {
                <div class="marginal-note" style="color: #003366; font-size: 0.75rem; font-weight: bold; margin-bottom: 2px;">
                    @node.MarginalNote
                </div>
            }

            <div style="display: flex; gap: 10px; align-items: flex-start;">
                @* 2. Render the Label (e.g., "8" or "(1)") *@
                <span class="node-label" style="font-weight: bold; min-width: 35px; color: #444;">@node.Label</span>
                
                @* 3. Conditional Content: Show Repeal Marker OR the Actual Text *@
                @if (isRepealed)
                {
                    <span class="repeal-text" style="color: #d73a49; font-style: italic; font-weight: 500;">
                        [Repealed @node.RepealDate.Value.Year]
                    </span>
                }
                else
                {
                    <span class="node-text">@node.Content</span>
                }
            </div>

            @* 4. Recursion: Render children (Subsections, Paragraphs) *@
            @if (node.Children != null && node.Children.Any())
            {
                <div class="node-children">
                    @foreach (var child in node.Children)
                    {
                        @RenderNode(child)
                    }
                </div>
            }
        </div>
    };

private int GetIndent(string? elementName) => elementName switch
{
    "Section" => 0,
    "Subsection" => 25,
    "Paragraph" => 50,
    "Subparagraph" => 75,
    "Clause" => 100,
    _ => 0
};
}
