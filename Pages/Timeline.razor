@page "/"
@inject LegislationTimeMachine.Services.LegislationStateService State
@using LegislationTimeMachine.Models
@using LegislationTimeMachine.Services

<div class="timeline-header" style="padding: 20px; background: #eee; border-bottom: 1px solid #ccc;">
    <div class="slider-controls">
        <label>Historical Snapshot (Year): @State.LeftYear</label>
        <input type="range" min="2003" max="2026" @bind-value="State.LeftYear" @bind-value:event="oninput" style="width: 100%;" />
    </div>
    <div class="metadata">
        <span>Comparing <strong>@State.LeftDate.ToShortDateString()</strong> to <strong>Current Laws</strong></span>
    </div>
</div>

<div class="diff-container" style="display: flex; height: 80vh; overflow: hidden; background: white;">
    
    @* Left Pane: Historical View *@
    <div class="pane" id="leftPane" style="flex: 1; overflow-y: auto; border-right: 2px solid #ddd;">
        <h3 style="padding: 10px; background: #f4f4f4; margin: 0;">Archive: @State.LeftYear</h3>
        <Virtualize Items="@LeftNodes" Context="historicalNode">
            <div class="node-row element-@historicalNode.ElementName @GetChangeClass(historicalNode.Fid)" data-fid="@historicalNode.Fid">
                @if (!string.IsNullOrEmpty(historicalNode.MarginalNote))
                {
                    <span class="marginal-note">@historicalNode.MarginalNote</span>
                }
                <span class="node-label">@historicalNode.Label</span>
                <span class="node-text">@historicalNode.Content</span>
                
                @if (historicalNode.Children.Any() && string.IsNullOrEmpty(historicalNode.Content))
                {
                    <div class="structural-info"><em>Structure: Subsections exist.</em></div>
                }
            </div>
        </Virtualize>
    </div>

    @* Right Pane: Current View *@
    <div class="pane" id="rightPane" style="flex: 1; overflow-y: auto;">
        <h3 style="padding: 10px; background: #f4f4f4; margin: 0;">Current Legislation</h3>
        <Virtualize Items="@RightNodes" Context="currentNode">
            <div class="node-row element-@currentNode.ElementName @GetChangeClass(currentNode.Fid)" data-fid="@currentNode.Fid">
                @if (!string.IsNullOrEmpty(currentNode.MarginalNote))
                {
                    <span class="marginal-note">@currentNode.MarginalNote</span>
                }
                <span class="node-label">@currentNode.Label</span>
                <span class="node-text">@currentNode.Content</span>

                @if (IsModified(currentNode.Fid))
                {
                    <span class="badge" style="background: #fbc02d; font-size: 0.7em; padding: 2px 5px; border-radius: 4px;">Modified</span>
                }
            </div>
        </Virtualize>
    </div>
</div>

@code {
    private List<LegislativeNode> LeftNodes = new();
    private List<LegislativeNode> RightNodes = new();
    private Dictionary<string, LegislativeDelta> DiffResults = new();

protected override async Task OnInitializedAsync()
{
    // Subscribe to state changes
    State.OnChange += async () => await RefreshData();
    
    // Load the mock data immediately
    LoadMockData(); 
}

private async Task RefreshData()
{
    // In a real scenario, this would fetch different files.
    // For the mock, we just re-run the hardcoded logic.
    LoadMockData();
    
    await Task.CompletedTask;
    StateHasChanged();
}

    private bool IsModified(string fid)
    {
        if (string.IsNullOrEmpty(fid)) return false;
        return DiffResults.TryGetValue(fid, out var delta) && delta.Type == ChangeType.Modified;
    }

    private string GetChangeClass(string fid) 
    {
        if (string.IsNullOrEmpty(fid) || !DiffResults.ContainsKey(fid)) return "unchanged";
        
        return DiffResults[fid].Type switch {
            ChangeType.Added => "diff-added",
            ChangeType.Removed => "diff-removed",
            ChangeType.Modified => "diff-mod",
            _ => "unchanged"
        };
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }

private void LoadMockData()
{

        LeftNodes.Clear();
    RightNodes.Clear();
    DiffResults.Clear();
    // Snapshot A: 2005 (Simple Section)
    var sectionOld = new LegislativeNode {
        Fid = "12345",
        Label = "3.1",
        MarginalNote = "INTERPRETATION",
        Content = "This section is a single sentence defining the scope of the Act.",
        ElementName = "Section"
    };
    LeftNodes = new List<LegislativeNode> { sectionOld };

    // Snapshot B: 2026 (The "Split" you identified)
    var sectionNew = new LegislativeNode {
        Fid = "12345", // Same FID
        Label = "3.1",
        MarginalNote = "INTERPRETATION",
        ElementName = "Section",
        Children = new List<LegislativeNode> {
            new LegislativeNode { 
                Fid = "12345-1", 
                Label = "(1)", 
                Content = "This section is a single sentence defining the scope of the Act.",
                ElementName = "Subsection" 
            },
            new LegislativeNode { 
                Fid = "67890", 
                Label = "(2)", 
                Content = "This is a brand new subsection added by an amending formula.",
                ElementName = "Subsection" 
            }
        }
    };
    RightNodes = new List<LegislativeNode> { sectionNew };

    // Mark it as Modified in the Diff Engine
    DiffResults["12345"] = new LegislativeDelta {
        Fid = "12345",
        Type = ChangeType.Modified,
        OldVersion = sectionOld,
        NewVersion = sectionNew
    };
}
}
